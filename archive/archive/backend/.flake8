[flake8]
max-line-length = 88
max-complexity = 10
exclude = 
    .git,
    __pycache__,
    venv,
    .venv,
    .tox,
    .eggs,
    *.egg-info,
    build,
    dist

ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by max-line-length)
    W503,  # line break before binary operator
    F401,  # imported but unused (handled by other tools)

per-file-ignores =
    __init__.py:F401

# Enable some optional warnings
select = 
    E,  # pycodestyle errors
    W,  # pycodestyle warnings
    F,  # Pyflakes
    C,  # mccabe complexity 